# Word Linker — optional cloud (Supabase). Copy to .env.local and fill in.
# When these are absent, the game runs fully offline (local saves only).
#
# Find these in your Supabase project: Settings → API.
# The anon/publishable key is safe to ship in a client build.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
